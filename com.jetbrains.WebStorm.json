{
    "id": "com.jetbrains.WebStorm",
    "runtime": "org.freedesktop.Sdk",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "webstorm-wrapper",
    "finish-args": [
        "--device=dri",
        "--env=IDEA_PROPERTIES=/app/bin/idea.properties",
        "--env=FLATPAK_ENABLE_SDK_EXT=node24",
        "--filesystem=home",
        "--filesystem=xdg-run/keyring",
        "--share=ipc",
        "--share=network",
        "--socket=x11",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets"
    ],
    "modules": [
        {
            "name": "webstorm",
            "build-commands": [
                "install -D -t ${FLATPAK_DEST}/bin/ apply_extra idea.properties",
                "install -Dm644 -t ${FLATPAK_DEST}/share/applications/ ${FLATPAK_ID}.desktop",
                "install -Dm644 -t ${FLATPAK_DEST}/share/metainfo/ ${FLATPAK_ID}.metainfo.xml",
                "install -Dm644 -t ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/ ${FLATPAK_ID}.svg"
            ],
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "extra-data",
                    "filename": "webstorm.tar.gz",
                    "only-arches": [
                        "x86_64"
                    ],
                    "sha256": "7bbdadf9f70f56667b99aa01c91f34d05fee993f1359e062e4043608ca7b6dbb",
                    "size": 1077824124,
                    "url": "https://download.jetbrains.com/webstorm/WebStorm-2025.3.4.tar.gz",
                    "x-checker-data": {
                        "code": "WS",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "extra-data",
                    "filename": "webstorm.tar.gz",
                    "only-arches": [
                        "aarch64"
                    ],
                    "sha256": "6bb31ce76b741df41fb1492d55a4630b2905947bccc2d3fbd2249414259ab56f",
                    "size": 1073216609,
                    "url": "https://download.jetbrains.com/webstorm/WebStorm-2025.3.4-aarch64.tar.gz",
                    "x-checker-data": {
                        "code": "WS",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.WebStorm.desktop"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.WebStorm.svg"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.WebStorm.metainfo.xml"
                },
                {
                    "type": "file",
                    "path": "idea.properties"
                },
                {
                    "type": "script",
                    "dest-filename": "apply_extra",
                    "commands": [
                        "tar xzf webstorm.tar.gz --strip-components=1",
                        "rm webstorm.tar.gz"
                    ]
                }
            ]
        },
        {
            "name": "ide-flatpak-wrapper",
            "buildsystem": "meson",
            "config-opts": [
                "-Deditor_binary=/app/extra/bin/webstorm",
                "-Deditor_title=WebStorm",
                "-Dprogram_name=webstorm-wrapper",
                "-Dfirst_run_template=README.md",
                "-Dflagfile_prefix=flatpak-webstorm"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flathub/ide-flatpak-wrapper.git",
                    "commit": "d581fd9b873acbf6fb22899aa388435f6c00f61a"
                },
                {
                    "type": "file",
                    "path": "README.md"
                }
            ]
        }
    ]
}
