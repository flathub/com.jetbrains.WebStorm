{
    "id": "com.jetbrains.WebStorm",
    "runtime": "org.freedesktop.Sdk",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "webstorm-wrapper",
    "finish-args": [
        "--device=dri",
        "--env=FLATPAK_ENABLE_SDK_EXT=node24",
        "--filesystem=home",
        "--filesystem=xdg-run/keyring",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets",
        "--talk-name=org.freedesktop.FileManager1"
    ],
    "modules": [
        {
            "name": "webstorm",
            "build-commands": [
                "cp -a WebStorm-*/* ${FLATPAK_DEST}",
                "cat idea.properties >> ${FLATPAK_DEST}/bin/idea.properties",
                "install -Dm644 -t ${FLATPAK_DEST}/share/applications/ ${FLATPAK_ID}.desktop",
                "install -Dm644 -t ${FLATPAK_DEST}/share/metainfo/ ${FLATPAK_ID}.metainfo.xml",
                "install -Dm644 -t ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/ ${FLATPAK_ID}.svg"
            ],
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "archive",
                    "strip-components": 0,
                    "only-arches": [
                        "x86_64"
                    ],
                    "sha256": "964ca21a07a120c91e234f5d7b6762369696c1a6654378624c15103b87215fec",
                    "url": "https://download.jetbrains.com/webstorm/WebStorm-2026.1.tar.gz",
                    "x-checker-data": {
                        "code": "WS",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "archive",
                    "strip-components": 0,
                    "only-arches": [
                        "aarch64"
                    ],
                    "sha256": "53d7bde3570494932b2052b7e562c3f6a002cbb1c9ed813362f7eba0d9ad4a6c",
                    "url": "https://download.jetbrains.com/webstorm/WebStorm-2026.1-aarch64.tar.gz",
                    "x-checker-data": {
                        "code": "WS",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.WebStorm.desktop"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.WebStorm.svg"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.WebStorm.metainfo.xml"
                },
                {
                    "type": "file",
                    "path": "idea.properties"
                }
            ]
        },
        {
            "name": "ide-flatpak-wrapper",
            "buildsystem": "meson",
            "config-opts": [
                "-Deditor_binary=/app/bin/webstorm",
                "-Deditor_title=WebStorm",
                "-Dprogram_name=webstorm-wrapper",
                "-Dfirst_run_template=README.md",
                "-Dflagfile_prefix=flatpak-webstorm"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flathub/ide-flatpak-wrapper.git",
                    "commit": "2881abaf9efc6e14923b8a0bb085275aaf2fbddf"
                },
                {
                    "type": "file",
                    "path": "README.md"
                }
            ]
        }
    ]
}
